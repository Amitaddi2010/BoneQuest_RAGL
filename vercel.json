{
  "public": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://51.21.162.26:8000/api/$1"
    },
    {
      "source": "/auth/(.*)",
      "destination": "http://51.21.162.26:8000/auth/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "http://51.21.162.26:8000/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

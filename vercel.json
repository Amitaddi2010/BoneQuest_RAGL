{
  "public": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://bonequest-backend.onrender.com/api/$1"
    },
    {
      "source": "/auth/(.*)",
      "destination": "https://bonequest-backend.onrender.com/auth/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://bonequest-backend.onrender.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
